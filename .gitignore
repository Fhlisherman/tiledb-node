# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/

# ── TypeScript build output ───────────────────────────────────────────────────
dist/
*.tsbuildinfo

# ── node-gyp / C++ native addon build artifacts ──────────────────────────────
build/
*.node
*.o
*.a

# ── Downloaded TileDB native libraries (fetched at install time) ──────────────
tiledb-dist/

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Runtime / OS ──────────────────────────────────────────────────────────────
*.pid
*.pid.lock
*.seed
.DS_Store

# ── Test coverage ─────────────────────────────────────────────────────────────
coverage/
*.lcov
.nyc_output/

# ── Environment files ─────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Editor / IDE ──────────────────────────────────────────────────────────────
.vscode/
.idea/

# ── pnpm ──────────────────────────────────────────────────────────────────────
.pnpm-store/
